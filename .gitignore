# Build output
/target
/dist

# Coverage artifacts
*.profraw
*.profdata
/lcov.info
/coverage

# Editor/OS noise
*.rs.bk
.DS_Store

# Local environment overrides (never commit secrets or machine-specific config)
.env
.env.local
.gh-secrets-state.json
# Personal Claude Code settings (per-machine hooks/permissions; not shared)
/.claude/settings.local.json
# Machine-local setup state (stamp/log from scripts/setup.sh; per-machine)
/.dev

# screencomp: commit the digest baseline (shots/baseline/*.json) and the README
# images (docs/screenshots/*.svg), but not the regenerated capture trees.
/shots/current/
/shots/verify/
/shots/review/
/site/
__pycache__/
