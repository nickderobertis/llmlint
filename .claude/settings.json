{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/scripts/session-setup.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(just setup)",
      "Bash(just setup-check)",
      "Bash(./scripts/setup.sh)",
      "Bash(bash scripts/setup.sh)",
      "Bash(bash scripts/setup-check.sh)",
      "Bash(just bootstrap)",
      "Bash(just check)",
      "Bash(just test)",
      "Bash(just test-e2e)",
      "Bash(just lint)",
      "Bash(just lint-live)",
      "Bash(just format)",
      "Bash(just fmt-check)",
      "Bash(just upgrade)",
      "Bash(just deps-check)",
      "Bash(just doctor)",
      "Bash(just msrv)",
      "Bash(just run:*)",
      "Bash(just bench)",
      "Bash(just bench-base)",
      "Bash(just bench-compare)",
      "Bash(just bench-cli)",
      "Bash(just bench-cli-smoke)",
      "Bash(just bench-allocs)",
      "Bash(just bench-instructions)",
      "Bash(just bench-all)",
      "Bash(just bench-tools)",
      "Bash(just profile:*)",
      "Bash(bash scripts/bench.sh:*)",
      "Bash(bash scripts/bench-instructions.sh:*)",
      "Bash(bash scripts/profile.sh:*)",
      "Bash(cargo bench:*)",
      "Bash(critcmp:*)",
      "Bash(hyperfine:*)",
      "Bash(valgrind:*)",
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo nextest:*)",
      "Bash(cargo run:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo llvm-cov:*)",
      "Bash(cargo doc:*)",
      "Bash(cargo deny:*)",
      "Bash(cargo machete:*)",
      "Bash(cargo update:*)",
      "Bash(oneharness:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)"
    ],
    "deny": []
  }
}
