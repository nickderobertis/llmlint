root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.rs]
max_line_length = 100

[*.{json,yml,yaml,toml,md}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[justfile]
indent_style = space
indent_size = 4
